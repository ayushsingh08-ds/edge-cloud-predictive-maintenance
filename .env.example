# ============================================
# PREDICTIVE MAINTENANCE SYSTEM
# Environment Configuration Template
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Update values for your environment
# 3. Never commit .env to git
#

# ----------------
# RabbitMQ Configuration
# ----------------
# Cloud/Main RabbitMQ Broker
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123
RABBITMQ_VHOST=/

# Management UI
RABBITMQ_MGMT_PORT=15672

# ----------------
# Edge RabbitMQ (for edge/cloud simulation)
# ----------------
EDGE_RABBITMQ_HOST=localhost
EDGE_RABBITMQ_PORT=5673
EDGE_RABBITMQ_USER=admin
EDGE_RABBITMQ_PASS=admin123

# ----------------
# AI Model Configuration
# ----------------
# Anomaly Detection
ANOMALY_THRESHOLD=0.7
ANOMALY_CONTAMINATION=0.1
ANOMALY_MODEL_PATH=edge/ai/models/isolation_forest.pkl

# RUL Prediction
RUL_MODEL_PATH=cloud/ai/model_registry/rul_lstm.h5
RUL_SEQUENCE_LENGTH=50
RUL_CRITICAL_HOURS=24
RUL_WARNING_HOURS=72
RUL_HEALTHY_HOURS=168

# ----------------
# Drift Detection
# ----------------
DRIFT_DETECTION_ENABLED=true
DRIFT_WINDOW_SIZE=1000
DRIFT_BASELINE_SIZE=1000
DRIFT_THRESHOLD_PSI=0.3
DRIFT_THRESHOLD_KS=0.05

# ----------------
# Retraining Configuration
# ----------------
RETRAIN_ON_DRIFT=true
RETRAIN_MIN_SAMPLES=500
RETRAIN_MAX_SAMPLES=10000
RETRAIN_AUTO_DEPLOY=true
MODEL_VERSION_KEEP=5

# ----------------
# Sensor Simulation
# ----------------
SENSOR_ID=sensor_001
SENSOR_FREQUENCY=1.0           # Hz (samples per second)
SENSOR_MODE=normal             # normal, degrading, failing

# Temperature (Celsius)
TEMP_BASELINE=75.0
TEMP_NOISE_STD=2.0
TEMP_MIN=60.0
TEMP_MAX=95.0

# Vibration (mm/s)
VIBRATION_BASELINE=0.5
VIBRATION_NOISE_STD=0.1
VIBRATION_MIN=0.0
VIBRATION_MAX=5.0

# Pressure (bar)
PRESSURE_BASELINE=50.0
PRESSURE_NOISE_STD=1.0
PRESSURE_MIN=40.0
PRESSURE_MAX=60.0

# Rotation Speed (RPM)
ROTATION_BASELINE=1500
ROTATION_NOISE_STD=50
ROTATION_MIN=1000
ROTATION_MAX=2000

# ----------------
# System Configuration
# ----------------
# Logging
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                # json or text
LOG_FILE=data/logs/system.log

# Data Directories
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MODEL_DIR=./data/models
LOG_DIR=./data/logs

# ----------------
# Dashboard Configuration
# ----------------
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_INTERVAL=1   # seconds
DASHBOARD_THEME=light          # light or dark
DASHBOARD_MAX_POINTS=1000      # max data points to display

# ----------------
# Performance & Limits
# ----------------
MAX_QUEUE_SIZE=10000
MESSAGE_BATCH_SIZE=100
WORKER_THREADS=4
MAX_MEMORY_MB=2048

# ----------------
# Database (Optional - for persistence)
# ----------------
# DATABASE_ENABLED=false
# DATABASE_TYPE=sqlite          # sqlite, postgresql
# DATABASE_PATH=data/database.db
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=predictive_maintenance
# DATABASE_USER=admin
# DATABASE_PASS=password

# ----------------
# Alerts & Notifications (Optional)
# ----------------
# ALERT_EMAIL_ENABLED=false
# ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_TO=admin@example.com
# ALERT_EMAIL_PASSWORD=your_password

# WEBHOOK_ENABLED=false
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ----------------
# Cloud Deployment (Optional)
# ----------------
# CLOUD_PROVIDER=aws            # aws, gcp, azure
# CLOUD_REGION=us-east-1
# S3_BUCKET=predictive-maintenance-models
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# ----------------
# Development Settings
# ----------------
DEBUG_MODE=false
ENABLE_PROFILING=false
ENABLE_METRICS=true