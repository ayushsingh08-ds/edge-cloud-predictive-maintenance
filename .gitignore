# ============================================
# PREDICTIVE MAINTENANCE SYSTEM
# Git Ignore File
# ============================================

# ----------------
# Python
# ----------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ----------------
# Data Files
# ----------------
# Raw data (don't commit large datasets)
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# Processed data
data/processed/*
!data/processed/.gitkeep

# Logs
data/logs/*
logs/
*.log
!data/logs/.gitkeep

# Temporary data
data/temp/*
data/tmp/*

# ----------------
# Machine Learning Models
# ----------------
# Trained models (large binary files)
*.h5
*.hdf5
*.pkl
*.pickle
*.pth
*.pt
*.onnx
*.pb
*.tflite
*.joblib

# Model directories
data/models/*
!data/models/.gitkeep
models/checkpoints/*
models/saved_models/*

# TensorBoard logs
tensorboard_logs/
runs/

# MLflow
mlruns/
mlartifacts/

# ----------------
# IDEs and Editors
# ----------------
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ----------------
# Operating System
# ----------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ----------------
# Docker
# ----------------
docker-compose.override.yml
.dockerignore

# ----------------
# RabbitMQ
# ----------------
rabbitmq_data/
mnesia/

# ----------------
# Secrets & Credentials
# ----------------
*.pem
*.key
*.cert
*.crt
secrets/
credentials.json
service-account.json

# ----------------
# Temporary Files
# ----------------
*.tmp
*.temp
*.bak
*.swp
*.swo

# ----------------
# Build Artifacts
# ----------------
*.tar.gz
*.zip
*.rar

# ----------------
# Project Specific
# ----------------
# Demo recordings
demos/*.mp4
demos/*.avi

# Large test datasets
test_data_large/

# Experiment results
experiments/
results/

# Generated documentation
docs/api/
docs/_build/

# Coverage reports
htmlcov/

# Profiling data
*.prof
*.lprof

# ----------------
# Keep These
# ----------------
# Keep .gitkeep files
!.gitkeep

# Keep example configs
!*.example
!*_example.*

# Keep README files
!README.md
!*/README.md